# ============================================================
# Travel Reimbursement Approval Agent - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --- LLM Provider Configuration ---
# Options: "openai" or "google"
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1

# Google Gemini Configuration
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash

# --- LLM Parameters ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# --- RAG Configuration ---
FAISS_INDEX_PATH=data/faiss_index
EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# --- Application ---
APP_NAME=Travel Reimbursement Approval Agent
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=INFO

# --- Currency API (optional, uses static rates as fallback) ---
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key-here

# --- Security ---
API_KEY_HEADER=X-API-Key
API_KEY=your-secret-api-key-here
